(* =========================================================
   LoRaDANCE — ProVerif Model v5
   Based on: "LoRaDANCE: Using the DNS for Mutual Authentication
   Without Pre-shared Keys" (WiMob 2024)
   + Standard LoRaWAN OTAA session key derivation

   ADDITIONS vs v4 (from OTAA procedure description):
   -------------------------------------------------------
   ADD-1 — DevAddr generated by NS (OTAA Step 2):
     NS generates a fresh 32-bit DevAddr and forwards it
     to JS inside the JoinReq message. JS embeds DevAddr
     in the encrypted Join-accept so ED can recover it.

   ADD-2 — Session keys NwkSKey and AppSKey (Steps 3 & 5):
     LoRaWAN OTAA session key derivation:
       NwkSKey = KDF_NwkSKey(AppKey, JoinNonce, DevNonce, DevEUI)
       AppSKey = KDF_AppSKey(AppKey, JoinNonce, DevNonce, DevEUI)
     Modeled with two distinct function symbols (different tags
     guarantee NwkSKey ≠ AppSKey even with identical inputs).
     Both JS (step 3) and ED (step 5) derive the same values.

   ADD-3 — NwkSKey transmitted JS→NS (OTAA Step 3):
     JS sends (devEUI, NwkSKey) to NS on c_ns in plaintext.
     Per OTAA: "The JS sends JoinAns to the NS with the
     NwkSKey." V7: c_ns is public → attacker reads NwkSKey.

   ADD-4 — testMessage now protected by AppSKey:
     Standard LoRaWAN: payload encrypted with AppSKey, not
     AppKey directly. Updated from v4.

   SYNTAX FIXES carried from v4:
   -------------------------------------------------------
   All v4 fixes retained (FIX-1 through FIX-7).
   Additional fixes in v5:
   FIX-8:  Q10 "==> not event(...)" → invalid syntax.
           Replaced with event-reachability queries using
           "==> false".
   FIX-9:  NS process had spurious
           "let (jaEUI: bitstring) = (jsAddr) in"
           — removed entirely.
   FIX-10: encJA_frame was a tuple (bitstring,bitstring,pkey,
           signature) assigned to a bitstring variable in NS
           — type mismatch. Redesigned: JS sends DNSSEC
           fragments directly to c (as in v4) and sends
           (devEUI, NwkSKey) separately to NS on c_ns.
           NS receives (devEUI, NwkSKey) from c_ns and records.
   FIX-11: Q11 used NS_GeneratedDevAddr which was never fired
           — replaced with NS_ReceivedNwkSKey reachability
           query confirming V7.

   VULNERABILITIES MODELED
   -------------------------------------------------------
   V1  DNS trust anchor compromise (steps 5,16).
   V2  No MAC over reassembled fragment frame (steps 12-15).
   V3  joinEUI_r not bound to TLSA name (step 3).
   V4  DevNonce absent from AppKey KDF — fixed procedurally.
   V5  Static ECDH keys, no forward secrecy (step 7).
   V6  NS routing DNS lookup unprotected (step 2).
   V7  NwkSKey sent JS→NS on public c_ns (step 3) [NEW v5].
   F1  "DNSSEC-verified" at JS is infrastructure assumption.
   F2  JoinNonce fresh per JS session — fixed in v4.
   F3  DNSSEC chain over public channel.
   F4  Trust anchor not pre-provisioned on ED.
   ========================================================= *)

(* ── Types ─────────────────────────────────────────────── *)
type skey.
type pkey.
type key.
type signature.

(* ── Asymmetric primitives ─────────────────────────────── *)
fun pk(skey): pkey.

fun sign(bitstring, skey): signature.
reduc forall m: bitstring, k: skey;
    checksign(sign(m, k), pk(k)) = m.

(* ── ECDH ───────────────────────────────────────────────── *)
(*
   Commutativity enables V1: attacker controls pkED_recv via
   DNS → computes same shared secret as honest JS.
*)
fun ecdh_raw(skey, pkey): key.
equation forall ska: skey, skb: skey;
    ecdh_raw(ska, pk(skb)) = ecdh_raw(skb, pk(ska)).

(* ── KDF — AppKey from ECDH ─────────────────────────────── *)
fun KDF(key): key.

(* ── Session key derivation (ADD-2) ────────────────────── *)
(*
   LoRaWAN 1.0.4 §6.2.5 session key derivation:
     NwkSKey = AES128(AppKey, 0x01 | JoinNonce | NetID | DevNonce | pad)
     AppSKey = AES128(AppKey, 0x02 | JoinNonce | NetID | DevNonce | pad)

   Two distinct function symbols model the 0x01/0x02 domain
   separation tag, guaranteeing NwkSKey ≠ AppSKey.
   Arguments: (AppKey, joinNonce, devNonce, devEUI)
*)
fun KDF_NwkSKey(key, bitstring, bitstring, bitstring): key.
fun KDF_AppSKey(key, bitstring, bitstring, bitstring): key.

(* ── Symmetric encryption ───────────────────────────────── *)
fun enc(bitstring, key): bitstring.
reduc forall m: bitstring, k: key;
    dec(enc(m, k), k) = m.

(* ── Hash ───────────────────────────────────────────────── *)
fun hash(bitstring): bitstring.

(* ── Long-term key pairs ────────────────────────────────── *)
free skED: skey [private].
free skJS: skey [private].

(* ── Channels ───────────────────────────────────────────── *)
free c:    channel.   (* LoRa radio / NS↔ED      — fully public *)
free dns:  channel.   (* DNS                      — fully public *)
free c_ns: channel.   (* NS↔JS forwarding path    — fully public *)
(*
   c_ns public: models V6 (routing attack) and V7
   (attacker reads NwkSKey in plaintext from JS→NS message).
*)

(* ── Secrets under test ─────────────────────────────────── *)
(*
   testMessage: application data protected by AppSKey (ADD-4).
   nwkTest: data protected by NwkSKey, tests V7 secrecy.
*)
free testMessage: bitstring [private].
free nwkTest:     bitstring [private].

(* ── Nonce tracking tables ──────────────────────────────── *)
table usedDevNonces(bitstring, bitstring).     (* devEUI, devNonce  *)
table edSeenJoinNonces(bitstring, bitstring).  (* devEUI, joinNonce *)

(* ── Events ─────────────────────────────────────────────── *)
event ED_StartJoin(bitstring, bitstring, bitstring).
                              (* devEUI, joinEUI, devNonce         *)
event ED_Authenticated(bitstring, pkey).
event ED_SessionReady(bitstring, key).
                              (* devEUI, AppKey                    *)
event ED_SessionKeysReady(bitstring, key, key).
                              (* devEUI, NwkSKey, AppSKey          *)

event NS_RoutedVia(bitstring).
                              (* jsAddr resolved by NS             *)
event NS_ReceivedNwkSKey(bitstring, key).
                              (* devEUI, NwkSKey received from JS  *)

event JS_ReceivedJoin(bitstring, bitstring, bitstring).
                              (* devEUI, joinEUI_r, devNonce       *)
event JS_AuthenticatedED(bitstring, pkey).
event JS_SessionReady(bitstring, key).
                              (* devEUI, AppKey                    *)
event JS_SessionKeysReady(bitstring, key, key).
                              (* devEUI, NwkSKey, AppSKey          *)

event DNSSEC_ChainVerified(bitstring, pkey).
event DNSSEC_TrustAnchorUsed(bitstring).

event DevNonceReplayed(bitstring, bitstring).
event JoinNonceReplayed(bitstring, bitstring).

(* =========================================================
   SECURITY QUERIES
   ========================================================= *)

(*
   Q1 — Secrecy of testMessage (application data via AppSKey)
   Expected: FALSE — V1+V5: attacker derives AppKey →
   AppSKey → decrypts testMessage.
*)
query attacker(testMessage).

(*
   Q2 — Secrecy of nwkTest (data protected by NwkSKey)
   Expected: FALSE — V1+V5: attacker derives AppKey →
   NwkSKey → decrypts nwkTest.
   Also: V7 — NwkSKey sent in plaintext on public c_ns.
   FIX-8: replaces invalid "not event(NS_ReceivedNwkSKey)"
*)
query attacker(nwkTest).

(*
   Q3 — Mutual authentication: ED completed → JS started
   Expected: FALSE — V1: attacker impersonates ED to JS.
*)
query devEUI: bitstring, k: key;
    event(ED_SessionReady(devEUI, k)) ==>
    event(JS_SessionReady(devEUI, k)).

(*
   Q4 — Origin authentication: JS received → ED started
   Expected: FALSE — V3: JS_ReceivedJoin fires before
   any check.
*)
query devEUI: bitstring, joinEUI: bitstring, dn: bitstring;
    event(JS_ReceivedJoin(devEUI, joinEUI, dn)) ==>
    event(ED_StartJoin(devEUI, joinEUI, dn)).

(*
   Q5 — Injective agreement on AppKey
   Expected: FALSE — V1 breaks injective agreement.
*)
query devEUI: bitstring, k: key;
    inj-event(ED_SessionReady(devEUI, k)) ==>
    inj-event(JS_SessionReady(devEUI, k)).

(*
   Q6 — Session key agreement: ED and JS derive same keys
   Expected: FALSE — V1: wrong pkED_recv at JS → JS derives
   AppKey under attacker key → different session keys than ED.
   FIX-8: replaces invalid "==> not event(...)" form.
*)
query devEUI: bitstring, nk: key, ak: key;
    event(ED_SessionKeysReady(devEUI, nk, ak)) ==>
    event(JS_SessionKeysReady(devEUI, nk, ak)).

(*
   Q7 — DevNonce uniqueness at JS
   Expected: FALSE — attacker sends same (devEUI,devNonce)
   twice → second triggers DevNonceReplayed.
*)
query devEUI: bitstring, dn: bitstring;
    event(DevNonceReplayed(devEUI, dn)) ==> false.

(*
   Q8 — JoinNonce uniqueness at ED
   Expected: FALSE — attacker constructs two fake encJA
   with same joinNonce via V1.
*)
query devEUI: bitstring, jn: bitstring;
    event(JoinNonceReplayed(devEUI, jn)) ==> false.

(*
   Q9 — NS routing integrity (V6)
   Expected: FALSE — attacker answers NS DNS query with
   any jsAddr.
*)
query jsAddr: bitstring;
    event(NS_RoutedVia(jsAddr)) ==> false.

(*
   Q10 — NwkSKey reaches NS (V7 reachability confirmation)
   Expected: FALSE — NS_ReceivedNwkSKey always fires since
   JS always outputs NwkSKey on public c_ns. The attacker
   on c_ns can read NwkSKey at the same step.
   FIX-11: replaces Q11 which used NS_GeneratedDevAddr
   (never fired).
*)
query devEUI: bitstring, nk: key;
    event(NS_ReceivedNwkSKey(devEUI, nk)) ==> false.

(* =========================================================
   PROCESS: DNS server (honest)
   Answers DevEUI queries with legitimate pkED.
   V1: attacker races on public dns channel.
   F1: "DNSSEC-verified" is an infrastructure assumption.
   ========================================================= *)
let DNS_ED_honest =
    in(dns, devEUI_q: bitstring);
    out(dns, pk(skED)).

(* =========================================================
   PROCESS: Network Server (NS)

   Models OTAA Steps 2 & 4 (redesigned in v5 — FIX-10):

   Step 2: Receive join-request from ED on c.
           Query DNS for JS address using JoinEUI (V6).
           Generate fresh DevAddr (ADD-1).
           Forward (joinMsg, devAddr) to JS on c_ns.

   Step 4: Receive (devEUI_from_js, NwkSKey) from JS on c_ns.
           Record NwkSKey reception — V7: c_ns is public,
           attacker can also read this message.
           (Join-accept fragments go directly c→ED from JS.)

   V6: DNS lookup on public dns channel.
   V7: NwkSKey received from JS on public c_ns.

   FIX-10: NS no longer tries to receive/relay the encJA_frame
   tuple (which had mixed types bitstring+pkey+signature).
   JS sends NwkSKey separately on c_ns; DNSSEC fragments go
   directly from JS to ED on c.
   FIX-9: Removed spurious "let (jaEUI) = (jsAddr) in".
   ========================================================= *)
let NS =
    (* Step 2a: Receive signed join-request from ED *)
    in(c, joinMsg: bitstring);

    (* Step 2b: DNS lookup for JS IP address via JoinEUI.
       V6: attacker can answer with malicious jsAddr.        *)
    out(dns, joinMsg);
    in(dns, jsAddr: bitstring);
    event NS_RoutedVia(jsAddr);

    (* Step 2c: Generate fresh DevAddr.
       Included in JoinReq so JS can embed it in Join-accept. *)
    new devAddr: bitstring;

    (* Step 2d: Forward JoinReq = (joinMsg, devAddr) to JS.   *)
    out(c_ns, (joinMsg, devAddr));

    (* Step 4: Receive NwkSKey from JS (ADD-3 / OTAA Step 3).
       JS sends (devEUI, NwkSKey) so NS can install the
       network session key for the ED.
       V7: c_ns is public — attacker reads NwkSKey here.    *)
    in(c_ns, (devEUI_from_js: bitstring, nwkSKey_recv: key));
    event NS_ReceivedNwkSKey(devEUI_from_js, nwkSKey_recv).

(* =========================================================
   PROCESS: End Device (ED)

   NEW in v5:
   - Derives NwkSKey and AppSKey after successful join (ADD-2)
   - Fires ED_SessionKeysReady(devEUI, NwkSKey, AppSKey)
   - testMessage encrypted with AppSKey (ADD-4)
   - Join-accept tuple now includes devAddr (ADD-1)

   VULNERABILITIES:
   V1  frag3 (pkJS:pkey) and frag4 (RRSIG:signature) from c.
   V2  Four fragments read independently — no frame MAC.
   V3  tlsaName = hash(joinEUI) satisfiable by attacker.
   V5  AppKey = KDF(ECDH(skED,pkJS)) — static, DevNonce∉KDF.
   F3  DNSSEC chain over public channel c.
   F4  Trust anchor not pre-provisioned on ED.
   ========================================================= *)
let ED(devEUI: bitstring, joinEUI: bitstring, devNonce: bitstring) =

    (* Step 1: Build and sign Join-request.
       ECDSA signature over (joinEUI,devEUI,devNonce) replaces
       the CMAC-based MIC of standard OTAA.                  *)
    event ED_StartJoin(devEUI, joinEUI, devNonce);
    let joinReqData = (joinEUI, devEUI, devNonce) in
    let sig = sign(joinReqData, skED) in
    out(c, (joinReqData, sig));

    (* Steps 13-15: Receive four fragments from public c.
       V2: no MAC over full reassembled frame.               *)
    in(c, frag1: bitstring);    (* encrypted JoinAccept       *)
    in(c, frag2: bitstring);    (* TLSA name = hash(joinEUI)  *)
    in(c, frag3: pkey);         (* pkJS from TLSA record      *)
    in(c, frag4: signature);    (* RRSIG over TLSA name       *)

    let encJA    = frag1 in
    let tlsaName = frag2 in

    (* Step 16a: Record trust anchor material.
       F4: arrives from public c, not pre-provisioned on ED. *)
    event DNSSEC_TrustAnchorUsed(tlsaName);

    (* Step 16b: Verify TLSA name matches JoinEUI.
       V3: attacker knows joinEUI from public join-request.  *)
    if tlsaName = hash(joinEUI) then

    (* Step 16c: Verify DNSSEC chain signature.
       V1+F3: attacker supplies consistent (frag3=pk(skb),
       frag4=sign(tlsaName,skb)) — check passes.            *)
    if checksign(frag4, frag3) = tlsaName then

    event DNSSEC_ChainVerified(tlsaName, frag3);

    (* Step 16d: Receive and bind pkJS.                       *)
    in(c, pkJS_certified: pkey);
    if pkJS_certified = frag3 then

    (* Step 16e: ECDH + AppKey.                               *)
    let shared = ecdh_raw(skED, pkJS_certified) in
    let AppKey = KDF(shared) in

    (* Decrypt JoinAccept *)
    let jaPlaintext = dec(encJA, AppKey) in

    (* Step 16f: Unpack Join-accept.
       v5: includes devAddr (ADD-1) and joinNonce (v4 F2).   *)
    let (ja_devEUI:    bitstring,
         ja_devNonce:  bitstring,
         ja_joinNonce: bitstring,
         ja_devAddr:   bitstring) = jaPlaintext in

    if ja_devEUI   = devEUI  then
    if ja_devNonce = devNonce then

    (* JoinNonce freshness check (F2 fix from v4).            *)
    get edSeenJoinNonces(=devEUI, =ja_joinNonce) in
        event JoinNonceReplayed(devEUI, ja_joinNonce)
    else (
        insert edSeenJoinNonces(devEUI, ja_joinNonce);
        event ED_Authenticated(devEUI, pkJS_certified);
        event ED_SessionReady(devEUI, AppKey);

        (* Step 5: Derive session keys (ADD-2).
           Uses same inputs as JS: AppKey, ja_joinNonce,
           ja_devNonce (= devNonce), devEUI.
           ja_devAddr used for network addressing but not
           included in key derivation per LoRaWAN spec.     *)
        let NwkSKey = KDF_NwkSKey(AppKey, ja_joinNonce, ja_devNonce, devEUI) in
        let AppSKey = KDF_AppSKey(AppKey, ja_joinNonce, ja_devNonce, devEUI) in

        event ED_SessionKeysReady(devEUI, NwkSKey, AppSKey);

        (* Application payload protected by AppSKey (ADD-4). *)
        out(c, enc(testMessage, AppSKey))
    ).

(* =========================================================
   PROCESS: Join Server (JS)

   NEW in v5:
   - Receives (joinMsg, devAddr) from NS (ADD-1)
   - Derives NwkSKey and AppSKey (ADD-2)
   - Sends (devEUI, NwkSKey) to NS on c_ns (ADD-3 / V7)
   - Join-accept now includes devAddr
   - DNSSEC fragments still sent directly to c (FIX-10)
   - nwkTest encrypted under NwkSKey for Q2 secrecy test

   VULNERABILITIES:
   V1  pkED_recv from public dns.
   V3  JS_ReceivedJoin fires before verification.
   V5  Static ECDH keys.
   V7  NwkSKey output on public c_ns.
   F3  DNSSEC chain over public c.
   ========================================================= *)
let JS(joinEUI: bitstring) =

    (* Receive JoinReq = ((joinReqData,sig), devAddr) from NS. *)
    in(c_ns, ((joinReqData: bitstring, sig: signature),
               devAddr: bitstring));
    let (joinEUI_r: bitstring,
         devEUI:    bitstring,
         devNonce:  bitstring) = joinReqData in

    (* V3: fires BEFORE any verification.                     *)
    event JS_ReceivedJoin(devEUI, joinEUI_r, devNonce);

    (* DevNonce replay detection.                             *)
    get usedDevNonces(=devEUI, =devNonce) in
        event DevNonceReplayed(devEUI, devNonce)
    else (
        insert usedDevNonces(devEUI, devNonce);

        (* DNS query for ED TLSA RR.
           V1: attacker answers with pk(skb).                *)
        out(dns, devEUI);
        in(dns, pkED_recv: pkey);

        (* Verify ED ECDSA signature.
           V1: if pkED_recv = pk(skb) → attacker sig passes.  *)
        if checksign(sig, pkED_recv) = joinReqData then (

            event JS_AuthenticatedED(devEUI, pkED_recv);

            (* ECDH + AppKey derivation.
               V5: AppKey = KDF(ECDH(skJS,pkED)) is static. *)
            let shared = ecdh_raw(skJS, pkED_recv) in
            let AppKey = KDF(shared) in

            (* Fresh JoinNonce — server-side counter (F2).   *)
            new joinNonce: bitstring;

            (* Derive session keys (ADD-2).
               NwkSKey: authenticates ED↔NS communications.
               AppSKey: encrypts application payload ED↔AS.
               Inputs: AppKey, joinNonce, devNonce, devEUI.  *)
            let NwkSKey = KDF_NwkSKey(AppKey, joinNonce, devNonce, devEUI) in
            let AppSKey = KDF_AppSKey(AppKey, joinNonce, devNonce, devEUI) in

            event JS_SessionKeysReady(devEUI, NwkSKey, AppSKey);

            (* Encrypt Join-accept (includes devAddr from NS). *)
            let joinAcceptData = (devEUI, devNonce, joinNonce, devAddr) in
            let encJA = enc(joinAcceptData, AppKey) in

            (* DNSSEC chain.                                  *)
            let tlsaName = hash(joinEUI) in

            (* Send JoinAns to NS: (devEUI, NwkSKey).
               ADD-3 / OTAA Step 3: NS needs NwkSKey.
               V7: c_ns is public — attacker reads NwkSKey.  *)
            out(c_ns, (devEUI, NwkSKey));

            (* Output nwkTest encrypted under NwkSKey.
               Q2 tests whether attacker can decrypt this.
               Expected FALSE: V7 exposes NwkSKey on c_ns.  *)
            out(c, enc(nwkTest, NwkSKey));

            (* Send DNSSEC fragments to ED on c (FIX-10).
               V2: four independent outputs — no frame MAC.  *)
            out(c, encJA);
            out(c, tlsaName);
            out(c, pk(skJS));
            out(c, sign(tlsaName, skJS));
            out(c, pk(skJS));

            event JS_SessionReady(devEUI, AppKey)
        )
    ).

(* =========================================================
   REPLAY ORACLE
   ========================================================= *)
let ReplayOracle =
    in(c_ns, captured: bitstring);
    out(c_ns, captured).

(* =========================================================
   MAIN PROCESS
   ========================================================= *)
process
    new devEUI:  bitstring;
    new joinEUI: bitstring;
    (
        ! ( new devNonce: bitstring;
            ED(devEUI, joinEUI, devNonce) )
        | ! JS(joinEUI)
        | ! NS
        | ! DNS_ED_honest
        | ! ReplayOracle
    )
